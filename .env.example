# PlantIQ Air-Gapped RAG System - Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=PlantIQ
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ============================================================================
# Security & Authentication
# ============================================================================
# CRITICAL: Generate strong random keys for production
# Use: openssl rand -base64 32
SECRET_KEY=changeme-use-strong-random-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# LDAP/Active Directory Configuration
#
# ── Local dev profile (default) ───────────────────────────────────────────────
# Connects to the containerised OpenLDAP service defined in docker-compose.yml.
# The OpenLDAP admin password must match LDAP_ADMIN_PASSWORD below.
# Set LDAP_MOCK=false to make real LDAP calls; set to true to bypass (unit-test mode).
LDAP_SERVER=ldap://ldap:389
LDAP_BASE_DN=dc=plantiq,dc=local
LDAP_BIND_DN=cn=admin,dc=plantiq,dc=local
# Dev placeholder — matches LDAP_ADMIN_PASSWORD below. NEVER use in production.
LDAP_BIND_PASSWORD=PlantIQ_Dev_Admin_2026
LDAP_USER_SEARCH_BASE=ou=users,dc=plantiq,dc=local
LDAP_MOCK=false
DIRECTORY_CONFIG_ENCRYPTION_KEY=<required-urlsafe-base64-32-byte-key>
# Admin password for the local OpenLDAP container (bitnami/openldap)
LDAP_ADMIN_PASSWORD=PlantIQ_Dev_Admin_2026
# Host port for the LDAP container (change if 1389 conflicts)
LDAP_HOST_PORT=1389
#
# ── Production / real AD profile (replace values above when deploying) ────────
# LDAP_SERVER=ldap://ad-server.facility.local:389
# LDAP_BASE_DN=DC=facility,DC=local
# LDAP_BIND_DN=CN=service-account,OU=Users,DC=facility,DC=local
# LDAP_BIND_PASSWORD=<store-in-secrets-manager-never-commit>
# LDAP_USER_SEARCH_BASE=OU=Users,DC=facility,DC=local
# LDAP_MOCK=false

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://plantiq:plantiq@localhost:5433/plantiq
POSTGRES_DB=plantiq
POSTGRES_USER=plantiq
# CRITICAL: Change these passwords immediately
# Use: openssl rand -base64 32
POSTGRES_PASSWORD=changeme

# CRITICAL SECURITY: PostgreSQL Authenticator Password
# This password is used by PostgREST to connect to PostgreSQL.
# MUST be rotated regularly and stored in secrets management (Docker secrets, K8s secrets, Vault).
# Generate with: openssl rand -base64 32
# NEVER use default value in production!
POSTGRES_AUTHENTICATOR_PASSWORD=change_me_in_production
POSTGRES_HOST_PORT=5433

# PostgREST (T-003 local stack)
PGRST_DB_SCHEMA=public
PGRST_DB_ANON_ROLE=plantig_anon
PGRST_SERVER_PROXY_URI=http://localhost:3000
POSTGREST_HOST_PORT=3000
JWT_AUDIENCE=plantig
JWT_PUBLIC_KEY_FILE=./backend/secrets/jwt-public.pem

# ============================================================================
# Vector Database Configuration
# ============================================================================
VECTOR_DB_TYPE=qdrant
VECTOR_DB_URL=http://localhost:6334
VECTOR_DB_COLLECTION=plantiq_documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ============================================================================
# LLM Configuration (OpenAI-compatible backend)
# ============================================================================
# Repo-root .env is the single source of truth for runtime model identity.
#
# TEXT_MODEL_ID        — used by the chat backend (Ollama).
#                        Must be an installed Ollama tag, e.g. qwen2.5:3b.
# PIPELINE_TEXT_MODEL_ID — used by the pipeline text reformatter (transformers).
#                        Must be a local model path or HF repo ID (NOT an Ollama tag).
#                        If unset, the reformatter falls back to TEXT_MODEL_ID, which
#                        will fail if TEXT_MODEL_ID is an Ollama tag.
#                        Operational policy: Stage 10 is container-first. If running
#                        Stage 10 on host/local for debugging, keep host transformers
#                        aligned to the repo range: >=5.0.0,<6.0.0.
# LLM_PROTOCOL         — Protocol for LLM inference server (http for local Ollama, https for remote/production).
#                        Default is 'http' for backwards compatibility with local dev setups.
#                        For production: set to 'https' and configure TLS in your LLM service.
TEXT_MODEL_ID=qwen3:4b
PIPELINE_TEXT_MODEL_ID=./models/Qwen3.5-4B
VISION_MODEL_ID=Qwen/Qwen3-VL-4B-Instruct
TEXT_INFERENCE_BACKEND=ollama
VISION_INFERENCE_BACKEND=transformers
LLM_BACKEND=ollama
LLM_PROTOCOL=http
LLM_UNLOAD_AFTER_REQUEST=false
LLM_DEMAND_HEARTBEAT_FILE=./data/artifacts/runtime/llm_last_used
LLM_STARTUP_WAIT_SECONDS=45
LLM_RETRY_INTERVAL_SECONDS=1.0
LLM_IDLE_TIMEOUT_SECONDS=300
LLM_REQUEST_WINDOW_SECONDS=30
LLM_HOST_PORT=11435
GPU_VRAM_GB=24
GENERATION_TIMEOUT_SECONDS=300
LLM_API_URL=http://localhost:11434
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
# Backward compatibility aliases still accepted by backend config:
# VLLM_API_URL, VLLM_MAX_TOKENS, VLLM_TEMPERATURE, VLLM_TOP_P

# ============================================================================
# RAG Configuration
# ============================================================================
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K_RETRIEVAL=5
RAG_ENABLE_RERANKING=true
RAG_CITATION_REQUIRED=true

# ============================================================================
# Pipeline Configuration
# ============================================================================
PIPELINE_WORKSPACE_DIR=./data/artifacts/hitl_workspace
PIPELINE_RAW_DOCS_DIR=./data/raw
PIPELINE_PROCESSED_DIR=./data/processed
PIPELINE_VALIDATION_EVIDENCE_DIR=./data/artifacts/validation_evidence

# VLM Settings (for document validation)
VLM_MAX_MODEL_LEN=4096
VLM_GPU_MEMORY_UTILIZATION=0.5
VLM_CPU_OFFLOAD_GB=100

# ============================================================================
# Frontend Configuration
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_APP_NAME=PlantIQ
NEXT_PUBLIC_FACILITY_NAME=BHE GT&S · Cove Point LNG Facility
NEXT_PUBLIC_ENABLE_BOOKMARKS=true
NEXT_PUBLIC_ENABLE_MULTI_TURN=true

# ============================================================================
# Docker Configuration
# ============================================================================
COMPOSE_PROJECT_NAME=plantiq
# Docling lifecycle policy (GPU contention mitigation)
# true  -> Docling starts only on demand (recommended)
# false -> keep legacy always-on behavior by setting DOCLING_AUTO_START=true
DOCLING_ON_DEMAND=true
DOCLING_AUTO_START=false
# Restart policy for docling-serve container; default 'no' enforces strict no-hold.
# Set to 'unless-stopped' only if you intentionally want persistent Docling runtime.
DOCLING_RESTART_POLICY=no

# ============================================================================
# Air-Gapped Deployment Settings
# ============================================================================
AIRGAP_MODE=true
OFFLINE_MODEL_CACHE=/models/cache
OFFLINE_VECTOR_DB_PERSISTENCE=/data/indexes

# ============================================================================
# Monitoring & Logging (Optional)
# ============================================================================
# FastAPI request logging threshold for slow-request warnings
SLOW_REQUEST_THRESHOLD_MS=500
LOG_REDACTION_ENABLED=true
SENSITIVE_QUERY_KEYS=token,access_token,refresh_token,api_key,key,secret,password,authorization,jwt

# Comma-separated path list to suppress low-value success logs
QUIET_LOG_PATHS=/health,/

# Comma-separated path prefixes that emit richer benchmark/troubleshooting logs
DETAILED_LOG_PATH_PREFIXES=/api/v1/chat,/api/v1/pipeline,/api/v1/auth,/api/docs

# PostgREST logging controls
PGRST_LOG_LEVEL=info
PGRST_LOG_QUERY=main-query

# ============================================================================
# Audit & Compliance
# ============================================================================
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_DIR=./logs/audit
COMPLIANCE_MODE=IEC-62443
