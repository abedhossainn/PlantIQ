# PostgREST API Configuration
NEXT_PUBLIC_POSTGREST_URL=http://localhost:3001
# Preferred FastAPI URL alias used by shared client resolver
NEXT_PUBLIC_API_URL=http://localhost:8001
# Local dev (outside Docker): backend maps to host port 8001
# Inside Docker (Next.js container): use http://backend:8000
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8001
