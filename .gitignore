# ============================================================================
# PlantIQ Air-Gapped RAG System - Git Ignore Configuration
# ============================================================================
# Keep only essential source code, configuration, and documentation
# Exclude working documents, test scripts, and temporary files

# === Python Bytecode & Cache ===
*.pyc
*.pyo
*.pyd
__pycache__/
*.egg-info/
dist/
build/
.eggs/
*.so

# === Virtual Environments ===
.venv/
venv/
ENV/
env/
.Python

# === Environment Variables & Secrets ===
.env
.env.local
.env.*.local
*.env
apps/api/secrets/
*.pem

# === Data Directories (Runtime, Not Source-Controlled) ===
data/artifacts/**
!data/artifacts/.gitkeep
data/raw/**
!data/raw/.gitkeep
data/processed/**
!data/processed/.gitkeep
apps/api/data/
data/indexes/**
!data/indexes/.gitkeep

# === Legacy AnythingLLM Storage ===
anythingllm-storage/

# === Build Artifacts & Node Modules ===
apps/web/.next/
apps/web/out/
apps/web/dist/
apps/web/node_modules/
apps/api/dist/
apps/pipeline/dist/
*.tsbuildinfo
apps/web/tsconfig.tsbuildinfo

# === IDE & Editor ===
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.github/
# Keep only one GitHub workflow tracked
!.github/
/.github/*
!.github/workflows/
/.github/workflows/*
!.github/workflows/sonar-scan.yml

# === Operating System ===
.DS_Store
Thumbs.db
.directory

# === Logs ===
*.log
logs.txt
# logs/ directory is NOT ignored — it contains test evidence files referenced in the capstone report
# Individual .log files within logs/ are covered by the *.log pattern above

# === Testing & Coverage ===
.coverage
htmlcov/
*.cover
.pytest_cache/
.nyc_output/
coverage/
validation_evidence/
data/*
apps/api/test_keys/
apps/api/scripts/
logs.txt

# Ignore tests everywhere by default
**/tests/
**/tests/**
**/__tests__/
**/__tests__/**
.metrics-venv/

# Keep tests inside app source packages tracked
!apps/api/tests/
!apps/api/tests/**
!apps/web/tests/
!apps/web/tests/**

# Re-ignore generated test cache artifacts
apps/api/tests/**/__pycache__/
apps/api/tests/**/*.pyc
apps/web/tests/**/__pycache__/
apps/web/tests/**/*.pyc

# === Temporary Files ===
*.tmp
*.temp
tmp/
temp/

# === Validation & Test Scripts (Non-Essential) ===
validate_t006.sh
validate_t004_t005.sh
test_docling.py
test_docling_diagnose.py
test_docling_v1.py

# === Development Documentation & Tooling ===
# These aid development but add no value for deployment consumers
docs/architecture/
docs/capstone/
docs/operations/
docs/security/
tools/
PROJECT_STATUS.md

# === Keep Essential Files ===
!README.md
!.env.example
!Makefile
!infra/docker/.gitkeep
!infra/scripts/.gitkeep
!.dockerignore
!Dockerfile
!docker-compose.yml
!pytest.ini
!pyproject.toml
!package.json
!tsconfig.json
!next.config.ts
!postcss.config.mjs
!vitest.config.ts

# Downloaded model weights (large files, not tracked)
models/

