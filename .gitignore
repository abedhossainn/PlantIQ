# ============================================================================
# PlantIQ Air-Gapped RAG System - Git Ignore Configuration
# ============================================================================
# Keep only essential source code, configuration, and documentation
# Exclude working documents, test scripts, and temporary files

# === Python Bytecode & Cache ===
*.pyc
*.pyo
*.pyd
__pycache__/
*.egg-info/
dist/
build/
.eggs/
*.so

# === Virtual Environments ===
.venv/
venv/
ENV/
env/
.Python

# === Environment Variables & Secrets ===
.env
.env.local
.env.*.local
*.env
backend/secrets/
*.pem

# === Data Directories (Runtime, Not Source-Controlled) ===
data/artifacts/**
!data/artifacts/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
backend/data
data/indexes/*
!data/indexes/.gitkeep

# === Legacy AnythingLLM Storage ===
anythingllm-storage/

# === Build Artifacts & Node Modules ===
frontend/.next/
frontend/out/
frontend/dist/
frontend/node_modules/
backend/dist/
pipeline/dist/
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# === IDE & Editor ===
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.github/

# === Operating System ===
.DS_Store
Thumbs.db
.directory

# === Logs ===
*.log
logs/
logs.txt

# === Testing & Coverage ===
.coverage
htmlcov/
*.cover
.pytest_cache/
.nyc_output/
coverage/
validation_evidence/
data/*
backend/test_keys/
backend/scripts/
logs.txt

# Ignore tests everywhere by default
**/tests/
**/tests/**
**/__tests__/
**/__tests__/**
.metrics-venv/

# Keep tests inside backend and frontend tracked
!backend/tests/
!backend/tests/**
!frontend/tests/
!frontend/tests/**

# === Temporary Files ===
*.tmp
*.temp
tmp/
temp/

# === Working Documents (Internal Use Only) ===
Documents/
CHECKPOINT_STRATEGY.md
RESTRUCTURE_PLAN.md
RESTRUCTURE_COMPLETE.md
PROJECT_STATUS.md
How to write clean code.md
T007_COMPLETION_SUMMARY.md
T008_T009_COMPLETION_SUMMARY.md
T010_COMPLETION_SUMMARY.md
