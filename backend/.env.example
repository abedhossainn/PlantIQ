# Backend Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql+asyncpg://plantig_authenticator:change_me@localhost:5433/plantig
SQL_DEBUG=false

# ============================================================================
# JWT Configuration
# ============================================================================
JWT_PRIVATE_KEY_PATH=/secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt-public.pem
JWT_ISSUER=plantig-auth
JWT_AUDIENCE=plantig
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# ============================================================================
# LDAP/AD Configuration
# ============================================================================
# Set USE_MOCK_LDAP=false to use real LDAP in production
USE_MOCK_LDAP=true
LDAP_SERVER_URL=ldap://ad.company.local
LDAP_BIND_DN=CN=svc_app,OU=Service,DC=company,DC=local
LDAP_BIND_PASSWORD=change_me
LDAP_USER_SEARCH_BASE=OU=Users,DC=company,DC=local

# ============================================================================
# Application Configuration
# ============================================================================
APP_ENV=development
LOG_LEVEL=INFO

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# Security
# ============================================================================
# Generate strong secret for production
SECRET_KEY=change_me_in_production

# ============================================================================
# Pipeline Configuration
# ============================================================================
PIPELINE_WORK_DIR=./data/artifacts/hitl_workspace
PIPELINE_PYTHON_PATH=./pipeline/.venv/bin/python3
PIPELINE_SCRIPT_PATH=./pipeline/src/cli/hitl_pipeline.py
PIPELINE_TIMEOUT_SECONDS=7200

# ============================================================================
# File Storage
# ============================================================================
UPLOAD_DIR=./data/raw
ARTIFACTS_DIR=./data/artifacts
MAX_UPLOAD_SIZE_MB=100

# ============================================================================
# Qdrant Vector Database
# ============================================================================
QDRANT_HOST=localhost
QDANT_PORT=6334
QDRANT_COLLECTION=plantig_documents
QDRANT_TIMEOUT=30

# ============================================================================
# LLM / VLM Inference Servers
# ============================================================================
# Model identity is owned by the repo-root `.env` contract.
# Do not redefine TEXT_MODEL_ID or VISION_MODEL_ID here.
# Preferred keys for chat text generation:
LLM_HOST=localhost
LLM_PORT=11434
LLM_BACKEND=ollama
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
# Set true to unload model after each request when LLM_BACKEND=ollama
LLM_UNLOAD_AFTER_REQUEST=false
LLM_DEMAND_HEARTBEAT_FILE=./data/artifacts/runtime/llm_last_used
LLM_STARTUP_WAIT_SECONDS=45
LLM_RETRY_INTERVAL_SECONDS=1.0
# Expose Ollama on host for local debugging (backend still uses internal docker network):
LLM_HOST_PORT=11435
# Optional dedicated endpoint for vision tasks in pipeline stages:
VLM_HOST=localhost
VLM_PORT=8000
# Backward compatibility: VLLM_* keys are still accepted as aliases.

# ============================================================================
# Embedding Model
# ============================================================================
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024

# ============================================================================
# RAG Configuration
# ============================================================================
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7
RAG_MAX_CONTEXT_LENGTH=8000

# ============================================================================
# WebSocket Configuration
# ============================================================================
WS_HEARTBEAT_INTERVAL=30
WS_MESSAGE_QUEUE_SIZE=100
